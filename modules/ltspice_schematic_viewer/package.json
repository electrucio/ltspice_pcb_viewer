{
  "name": "ltspice_schematic_viewer",
  "version": "0.1.0",
  "description": "Framework-agnostic web component to visualize, explore, and highlight nets and components from LTspice schematics (.asc).",
  "type": "module",
  "main": "./dist/ltspice_schematic_viewer.js",
  "module": "./dist/ltspice_schematic_viewer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ltspice_schematic_viewer.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite demo --config vite.config.ts",
    "build": "tsc --emitDeclarationOnly && vite build",
    "preview": "vite preview demo --config vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ltspice",
    "schematic",
    "spice",
    "eda",
    "web-component",
    "netlist",
    "svg"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}