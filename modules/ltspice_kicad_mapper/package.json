{
  "name": "ltspice_kicad_mapper",
  "version": "0.1.0",
  "description": "Web component to map nets and components between an LTspice schematic and a KiCad schematic, with import/export of the mapping.",
  "type": "module",
  "main": "./dist/ltspice_kicad_mapper.js",
  "module": "./dist/ltspice_kicad_mapper.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/ltspice_kicad_mapper.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "dev": "vite demo",
    "build": "vite build",
    "preview": "vite preview demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["ltspice", "kicad", "mapping", "netlist", "eda", "web-component"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
