{
  "name": "pcb_mesh",
  "version": "0.1.0",
  "description": "Copper-geometry extraction + triangular meshing for KiCad PCBs: per-layer, per-net copper regions (tracks ∪ pads ∪ vias ∪ zone fills − drills) triangulated into FEM-ready meshes. First building block of the parasitic-extraction engine (module M2 seed).",
  "type": "module",
  "main": "./dist/pcb_mesh.js",
  "module": "./dist/pcb_mesh.js",
  "exports": {
    ".": {
      "import": "./dist/pcb_mesh.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite demo --config vite.config.ts",
    "build": "vite build",
    "preview": "vite preview demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "kicad",
    "pcb",
    "mesh",
    "triangulation",
    "parasitic-extraction",
    "eda"
  ],
  "license": "MIT",
  "dependencies": {
    "cdt2d": "^1.0.0",
    "earcut": "^3.0.1",
    "polygon-clipping": "^0.15.7"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
